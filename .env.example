# ============================================================
# MaoAI 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/maoai

# ── OAuth 认证 ──────────────────────────────────────────────
# 从 Manus 开放平台获取
VITE_APP_ID=
JWT_SECRET=                    # 与 OAUTH_SERVER_URL 的 JWT 签名密钥一致
OAUTH_SERVER_URL=https://oauth.manus.im
OWNER_OPEN_ID=                 # 管理员 Open ID

# ── 本地节点注册 ────────────────────────────────────────────
# 用于注册本地 AI 节点（AutoClaw 等）的共享密钥
NODE_REGISTRATION_TOKEN=

# ── 云端模型 API Keys ───────────────────────────────────────

# 智谱 BigModel 开放平台（用于 GLM-4 / GLM-5V-TurboAutoClaw）
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# Z.ai 开放平台（用于 Z.ai GLM-5 / GLM-4.7）
# 获取地址: https://chat.z.ai 或 https://docs.z.ai
ZAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Groq（免费高速）
GROQ_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# ── 内置 Forge API（Manus 云端）────────────────────────────
# 一般无需修改，留空使用默认 Manus Forge
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=https://forge.manus.im

# ── 图片生成（Nano Banana / Forge Image）───────────────────
IMAGE_GEN_API_KEY=
IMAGE_GEN_API_URL=

# ══════════════════════════════════════════════════════════════
# 视频生成 API Keys
# ══════════════════════════════════════════════════════════════

# ── Runway (via useapi.net) ───────────────────────────────────
# useapi.net 是 Runway 的统一代理，支持 Gen-4.5 / Gen-4 / Veo 3.1 / Kling / Wan
# ⚠️ Sora 2 已被 OpenAI 关停，请勿使用 sora-2 / sora-2-pro
# 获取地址: https://useapi.net (需注册并绑定 Runway 账号)
RUNWAY_API_KEY=

# ── 快手可灵 Kling ───────────────────────────────────────────
# Kling AI 原生 API，支持 kling-video-o1 / kling-v2.6-pro / kling-v2.5-turbo
# 获取地址: https://klingapi.com/zh/pricing (注册即送 $1 额度)
KLING_API_KEY=

# ── 火山引擎即梦 Jimeng ─────────────────────────────────────
# 需同时配置 API URL（从火山引擎控制台获取）和 API Key
# 获取地址: https://console.volcengine.com → 即梦AI → API调用
# 获取 API Key 后，还需开通"即梦AI-视频生成3.0"服务
JIMENG_API_URL=https://visual.volces.com
JIMENG_API_KEY=

# ── 部署平台 ───────────────────────────────────────────────
NODE_ENV=production
