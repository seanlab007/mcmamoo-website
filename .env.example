# MaoAI 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ── AI API Keys ────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_API_KEY=your-google-api-key
ZHIPU_API_KEY=your-zhipu-api-key
GROQ_API_KEY=your-groq-api-key
WORKBUDDY_API_KEY=sk-your-workbuddy-api-key
ANTHROPIC_API_KEY=sk-your-anthropic-api-key

# ── RunPod ─────────────────────────────────────────────────────────────
RUNPOD_API_KEY=your-runpod-api-key

# ── 腾讯云 ─────────────────────────────────────────────────────────────
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key

# ── Brave Search ───────────────────────────────────────────────────────
BRAVE_API_KEY=your-brave-api-key

# ── OpenClaw Gateway ───────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=your-openclaw-token

# ── OpenCLI ─────────────────────────────────────────────────────────────
OPENCLI_MCP_PORT=19825
OPENCLI_ROOT=/Users/daiyan/Desktop/opencli

# ── Ollama 本地模型 ───────────────────────────────────────────────────
# Ollama 本地服务地址
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true

# 本地嵌入模型配置 (用于 RAG/语义搜索)
OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
OLLAMA_EMBEDDING_DIMENSIONS=768

# ── Google AI Studio (Gemma 4) ─────────────────────────────────────────
# Google AI Studio API Key - 用于访问 Gemma 4 系列模型
# 申请地址: https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO_API_KEY=your-google-ai-studio-api-key-here

# ── Z.ai 平台 ─────────────────────────────────────────────────────────
ZAI_API_KEY=your-zai-api-key-here

# ── 其他配置 ──────────────────────────────────────────────────────────
# GitHub Token（用于 github_push/github_read 工具）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily API Key（可选，用于增强搜索）
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeerFlow URL（如果部署了深度研究服务）
DEERFLOW_URL=http://localhost:2026
