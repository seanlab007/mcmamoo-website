# ============================================================
# MaoAI 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/maoai

# ── OAuth 认证 ──────────────────────────────────────────────
# 从 Manus 开放平台获取
VITE_APP_ID=
JWT_SECRET=                    # 与 OAUTH_SERVER_URL 的 JWT 签名密钥一致
OAUTH_SERVER_URL=https://oauth.manus.im
OWNER_OPEN_ID=                 # 管理员 Open ID

# ── 本地节点注册 ────────────────────────────────────────────
# 用于注册本地 AI 节点（AutoClaw 等）的共享密钥
NODE_REGISTRATION_TOKEN=

# ── 云端模型 API Keys ───────────────────────────────────────

# 智谱 BigModel 开放平台（用于 GLM-4 / GLM-5V-TurboAutoClaw）
# 获取地址: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# Z.ai 开放平台（用于 Z.ai GLM-5 / GLM-4.7）
# 获取地址: https://chat.z.ai 或 https://docs.z.ai
ZAI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Groq（免费高速）
GROQ_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# ── 内置 Forge API（Manus 云端）────────────────────────────
# 一般无需修改，留空使用默认 Manus Forge
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=https://forge.manus.im

# ── 图片生成（Nano Banana / Forge Image）───────────────────
IMAGE_GEN_API_KEY=
IMAGE_GEN_API_URL=

# ── 部署平台 ───────────────────────────────────────────────
NODE_ENV=production
