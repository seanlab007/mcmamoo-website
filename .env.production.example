# MaoAI MPO 生产环境配置
# 复制为 .env.production 并填写真实值

# ─── 数据库 ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/maoai_db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI 服务密钥 ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
ZHIPU_API_KEY=your-glm-key
RUNPOD_API_KEY=your-runpod-key

# ─── MPO 核心配置 ─────────────────────────────────────────────────────────────
# Python 可执行路径（容器内可能是 python3）
MPO_PYTHON_BIN=python3
# MPO 最大并行 Worker 数
MPO_MAX_WORKERS=10
# MPO 单任务超时（秒）
MPO_TIMEOUT_SEC=600
# MPO 成功分数阈值 0.0-1.0
MPO_SCORE_THRESHOLD=0.80
# 是否开启并行模式
MPO_ENABLE_PARALLEL=true

# ─── DecisionLedger 持久化 ────────────────────────────────────────────────────
# Ledger SQLite 路径（仅本地开发；生产用 PostgreSQL）
LEDGER_DB_PATH=/app/data/decision_ledger.db
# 生产环境 Ledger 使用同一个 DATABASE_URL（Drizzle ORM）
LEDGER_USE_POSTGRES=true

# ─── 监控告警 ─────────────────────────────────────────────────────────────────
# 成功率告警阈值（低于此值触发告警）
ALERT_SUCCESS_RATE_THRESHOLD=70
# 平均耗时告警阈值（秒）
ALERT_AVG_DURATION_THRESHOLD=120
# 失败任务数告警阈值
ALERT_FAILED_COUNT_THRESHOLD=10

# ─── 应用服务 ─────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
VITE_API_BASE=https://api.maoai.vip
# JWT/Cookie 密钥（32 字符以上随机串）
SESSION_SECRET=your-long-random-secret-at-least-32-chars

# ─── WebSocket 服务（MPO 实时推送）────────────────────────────────────────────
WS_PORT=8765
WS_HOST=0.0.0.0
