
# 查看帮助
python3 ~/.workbuddy/maoai-core/maoai_task_cli.py --help

# 启动演示
python3 ~/.workbuddy/maoai-core/maoai_task_cli.py start

# 并行处理文件
python3 ~/.workbuddy/maoai-core/maoai_task_cli.py parallel \
  -w /path/to/project \
  -f file1.ts file2.ts file3.ts \
  "修复类型错误"

# MaoAI Docker 
Compose 环境变量配置
# 复制此文件为 .env 并填写实际值

# 数据库
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/maoai

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# AI API Keys
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
