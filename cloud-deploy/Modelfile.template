# Gemma-31B-CRACK Modelfile
# 优化参数配置

FROM ./gemma-4-31b-jang-crack-Q4_K_M.gguf

# ── 显存优化参数 ────────────────────────────────────────────────
# 确保 60 层全部加载到 GPU
PARAMETER num_gpu 60

# 上下文长度（根据显存余量调整）
# RTX 4090 24GB: 建议 4096-8192
# A100 40GB: 建议 8192-16384
# A100 80GB: 建议 16384-32768
PARAMETER num_ctx 8192

# 温度参数（去审查模型建议降低以保持逻辑连贯）
PARAMETER temperature 0.7

# Top-P 采样
PARAMETER top_p 0.9

# ── 安全限制 ────────────────────────────────────────────────────
# 限制 Ollama 仅允许特定来源访问（部署后替换为 MaoAI 服务器 IP）
ENV OLLAMA_ORIGINS="https://maoyan.vip,https://zhengyuanzhiyin.com"

# 最大并发请求
ENV OLLAMA_MAX_LOADED_MODELS 1

# ── 内存优化 ────────────────────────────────────────────────────
# 禁用内存映射，减少 Swap 使用
PARAMETER mmul 1
