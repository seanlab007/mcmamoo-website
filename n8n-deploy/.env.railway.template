# n8n on Railway — 部署配置
# ============================================================
# 用法：
#   1. 将此目录部署到 Railway（与 mcmamoo-website 同项目或关联项目）
#   2. 在 Railway Dashboard 添加 PostgreSQL 插件（或连接 Supabase）
#   3. 填入以下环境变量
#   4. Railway 自动构建并启动

# ============================================================
# 数据库（优先使用 Railway PostgreSQL 插件）
# ============================================================
# 若用 Railway 自带的 PostgreSQL：
#   DATABASE_URL = postgres://postgres:[password]@localhost:5432/n8n
#
# 若用 Supabase 直连（需替换为你的 Supabase PostgreSQL 连接串）：
#   DATABASE_URL = postgres://postgres.[project_ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres
#
# ⚠️ 必须设置 N8N_ENCRYPTION_KEY（任意 32+ 字符随机字符串）
# ⚠️ 必须设置 DB 类型

# n8n 数据库类型（必须设为 postgresdb）
N8N_DATABASE_TYPE=postgresdb
N8N_DATABASE_POSTGRESDB_CONNECTION_LIMIT=10

# ============================================================
# 基础鉴权
# ============================================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ============================================================
# 安全与加密
# ============================================================
# n8n 工作流数据加密密钥（必填，不要泄露）
# 生成方式：openssl rand -hex 32
N8N_ENCRYPTION_KEY=REPLACE_WITH_32_PLUS_CHAR_RANDOM_KEY

# Cookie 安全
N8N_SECURE_COOKIE=false

# ============================================================
# Webhook 与协议
# ============================================================
# 部署后替换为实际的 Railway 域名
WEBHOOK_URL=https://your-n8n-app.up.railway.app
N8N_PROTOCOL=http
N8N_PORT=5678
N8N_HOST=0.0.0.0

# ============================================================
# 功能开关
# ============================================================
# 允许匿名 Webhook 访问（按需开启）
N8N_PUBLIC_WEBHOOK_ENDPOINT_TYPE=v1

# 时区
GENERIC_TIMEZONE=Asia/Shanghai

# 关闭遥测
N8N_DIAGNOSTICS_ENABLED=false

# 日志级别
LOG_LEVEL=info

# ============================================================
# 执行模式（可选优化）
# ============================================================
# 队列模式（需要 Redis，大规模并发时开启）
# EXECUTIONS_MODE=queue
# QUEUE_BULL_REDIS_HOST=redis
# QUEUE_BULL_REDIS_PORT=6379
